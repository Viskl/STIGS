<#
.SYNOPSIS
    This PowerShell script ensures that the Security event log size is configured
    to 1024000 KB or greater.
.NOTES
    Author          : Sebastian Chrzanowski
    LinkedIn        : www.linkedin.com/in/sebastian-chrzanowski-75a8a41a4/
    GitHub          : github.com/Viskl
    Date Created    : 2025-03-11
    Last Modified   : 2025-03-11
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN10-AU-000505
.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 
.USAGE
    Run the script with administrator privileges.
    Example syntax:
    PS C:\> .\remediation_WN10-AU-000505.ps1
#>

$registryPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\EventLog\Security"
$valueName    = "MaxSize"
$valueData    = 1024000

# Create registry path if it does not exist
if (-not (Test-Path $registryPath)) {
    New-Item -Path $registryPath -Force | Out-Null
    Write-Host "Registry path created: $registryPath"
}

# Check if current value is already equal or greater than required
$currentValue = (Get-ItemProperty -Path $registryPath -Name $valueName -ErrorAction SilentlyContinue).$valueName
if ($currentValue -ge $valueData) {
    Write-Host "Current value ($currentValue KB) already meets or exceeds the required minimum ($valueData KB). No changes made." -ForegroundColor Green
    exit 0
}

# Set the registry value
Set-ItemProperty -Path $registryPath -Name $valueName -Value $valueData -Type DWord
Write-Host "Registry value '$valueName' set to '$valueData' KB at '$registryPath'"

# Verify the setting was applied
$appliedValue = (Get-ItemProperty -Path $registryPath -Name $valueName).$valueName
Write-Host "Verification - Current value: $appliedValue KB"
