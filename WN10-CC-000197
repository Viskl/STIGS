<#
.SYNOPSIS
    This PowerShell script ensures that Microsoft consumer experiences are turned off.
.NOTES
    Author          : Sebastian Chrzanowski
    LinkedIn        : www.linkedin.com/in/sebastian-chrzanowski-75a8a41a4/
    GitHub          : github.com/Viskl
    Date Created    : 2025-03-11
    Last Modified   : 2025-03-11
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN10-CC-000197
.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 
.USAGE
    Run the script with administrator privileges.
    Example syntax:
    PS C:\> .\remediation_WN10-CC-000197.ps1
#>

# Check for Windows 10 v1507 LTSB - setting is N/A for that version
$buildNumber = (Get-ItemProperty "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion").CurrentBuild
if ($buildNumber -eq "10240") {
    Write-Host "Windows 10 v1507 LTSB detected (Build $buildNumber). This setting is N/A for this version. Exiting." -ForegroundColor Yellow
    exit 0
}

$registryPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent"
$valueName    = "DisableWindowsConsumerFeatures"
$valueData    = 1

# Create registry path if it does not exist
if (-not (Test-Path $registryPath)) {
    New-Item -Path $registryPath -Force | Out-Null
    Write-Host "Registry path created: $registryPath"
}

# Set the registry value
Set-ItemProperty -Path $registryPath -Name $valueName -Value $valueData -Type DWord
Write-Host "Registry value '$valueName' set to '$valueData' at '$registryPath'"

# Verify the setting was applied
$appliedValue = Get-ItemProperty -Path $registryPath -Name $valueName
Write-Host "Verification - Current value: $($appliedValue.$valueName)"
