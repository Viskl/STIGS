<#
.SYNOPSIS
    This PowerShell script ensures that the account lockout duration is configured to 15 minutes or greater.
.NOTES
    Author          : Sebastian Chrzanowski
    LinkedIn        : www.linkedin.com/in/sebastian-chrzanowski-75a8a41a4/
    GitHub          : github.com/Viskl
    Date Created    : 2025-03-11
    Last Modified   : 2025-03-11
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN10-AC-000005
.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 
.USAGE
    Run the script with administrator privileges.
    Example syntax:
    PS C:\> .\remediation_WN10-AC-000005.ps1
#>

# Set account lockout duration to 15 minutes
net accounts /lockoutduration:15

# Verify the setting was applied
$output = net accounts | Select-String "Lockout duration"
Write-Host "Current setting: $output"
